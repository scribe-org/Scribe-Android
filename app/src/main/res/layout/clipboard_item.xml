<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/clipboard_item_bg"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Header Row: "Copied text" label on left, clipboard icon on right -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copied text"
            android:textColor="#999999"
            android:textSize="11sp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <ImageView
            android:id="@+id/pin_icon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_copy_vector"
            android:tint="#999999"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:visibility="visible" />

    </RelativeLayout>

    <!-- Main Content: bold centered text -->
    <TextView
        android:id="@+id/clip_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:gravity="center"
        android:textColor="@color/text_color"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="2dp"
        android:paddingBottom="4dp" />

</LinearLayout>
